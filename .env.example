# =============================================================================
# BaatCheet Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env — only .env.example goes in the repo.
# =============================================================================

# =============================================================================
# DISCORD OAUTH2 (Phase 0/1)
# =============================================================================
# Create an application at: https://discord.com/developers/applications
# Under OAuth2 > General:
#   - Add redirect URI: baatcheet://callback
#   - Copy the Client ID (NOT the secret — we use PKCE, public client)
DISCORD_CLIENT_ID=
# Alias exposed to the renderer (Vite) and forwarded to the Rust `start_discord_login` command (D-impl-2).
VITE_DISCORD_CLIENT_ID=

# =============================================================================
# CONVEX CLOUD (Phase 0)
# =============================================================================
# Create a project at: https://convex.dev/
# Run `bunx convex dev` to get these values, or find them in the Convex dashboard.
#
# The URL your frontend uses to talk to Convex (e.g., https://your-project-123.convex.cloud)
VITE_CONVEX_URL=

# Deploy key for programmatic access (optional for local dev, required for CI/CD)
CONVEX_DEPLOY_KEY=

# =============================================================================
# LIVEKIT SFU (Phase 6 — group voice)
# =============================================================================
# Deploy LiveKit on your Coolify VM.
# Get these from your LiveKit server config or dashboard.
#
# LiveKit server URL (e.g., wss://livekit.yourdomain.com)
VITE_LIVEKIT_URL=

# API key + secret from LiveKit server config.
# IMPORTANT: LIVEKIT_API_KEY and LIVEKIT_API_SECRET are CONVEX SERVER env —
# set them via `bunx convex env add LIVEKIT_API_KEY ...` and
# `bunx convex env add LIVEKIT_API_SECRET ...`. They are NOT read from .env.local
# and must NEVER reach the client (the API secret grants token-minting authority).
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# =============================================================================
# ICE SERVERS / COTURN (Phase 4/6 — NAT traversal)
# =============================================================================
# Deploy coturn on your Coolify VM (shared for 1:1 WebRTC + LiveKit fallback).
# Provide the ICE servers as a JSON array of RTCIceServer objects.
# If unset, falls back to Google's public STUN (stun:stun.l.google.com:19302).
#
# Example (replace <vm-host> and <secret> with your coturn config):
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:<vm-host>:3478","username":"baatcheet","credential":"<secret>"}]
VITE_ICE_SERVERS=

# =============================================================================
# GIPHY API (Rich messaging — GIF picker)
# =============================================================================
# Get a beta key at: https://developers.giphy.com/dashboard/?create=true
# Beta keys are client-safe (Vite-embedded). Rate-limited but sufficient for v1.
VITE_GIPHY_API_KEY=
