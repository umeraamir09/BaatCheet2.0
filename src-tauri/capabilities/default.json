{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:window:allow-close",
    "opener:default",
    "process:default",
    "updater:default",
    "deep-link:default",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister"
  ]
}
